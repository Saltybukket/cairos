  {
    "name": "Typo tolerant C++ header",
    "command": [
      "python3",
      "-m",
      "cairos.cli",
      "plan",
      "erstelle",
      "heder",
      "Player"
    ],
    "expected_contains": [
      "Summary: Create C++ header for class Player.",
      "Source: template:cpp-header"
    ],
    "expected_stderr": "",
