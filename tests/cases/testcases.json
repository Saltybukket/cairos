    "expected_contains": [
      "Configured Gemini AI",
      "provider=gemini",
      "model=gemini-1.5-flash",
      "api_key_env=GEMINI_API_KEY"
    ],
    "expected_stderr": "",
    "expected_exit": 0
  },
  {
    "name": "Dry-run does not execute",
    "command": [
      "python3",
      "-m",
      "cairos.cli",
      "--dry-run",
      "create",
      "folder",
      "docs"
    ],
    "expected_contains": [
      "Summary: Create folder docs.",
      "Dry-run: no steps executed."
    ],
    "expected_stderr": "",
    "expected_exit": 0
  },
  {
    "name": "Preview C++ header",
