  },
  {
    "name": "Rules affect C++ namespace",
    "command": [
      "python3",
      "-c",
      "from pathlib import Path; from cairos.rules import set_rule; from cairos.templates import plan_from_template; set_rule('cpp.namespace','archmage'); p=plan_from_template('create cpp header Player'); print(p.steps[1].content)"
    ],
    "expected_contains": [
      "namespace archmage",
      "} // namespace archmage"
    ],
    "expected_stderr": "",
    "expected_exit": 0
  },
  {
    "name": "Context filters secrets",
    "command": [
      "python3",
      "-c",
      "from pathlib import Path; Path('.env').write_text('SECRET=1'); Path('id_rsa').write_text('x'); Path('main.py').write_text('print(1)'); from cairos.context import context_json; print(context_json())"
    ],
    "expected_contains": [
      "\"project_type\": \"python\"",
      "\"path\": \"main.py\""
    ],
    "expected_stderr": "",
    "expected_exit": 0
  },
  {
    "name": "Explain git reset soft",
    "command": [
      "python3",
      "-m",
      "cairos.cli",
      "explain",
      "git",
      "reset",
      "--soft",
      "HEAD~1"
    ],
    "expected_contains": [
      "Moves the current branch pointer",
      "keeps changes staged",
      "What stays unchanged"
    ],
    "expected_stderr": "",
    "expected_exit": 0
  },
  {
    "name": "History command empty",
    "command": [
      "python3",
      "-m",
      "cairos.cli",
      "history"
    ],
    "expected_contains": [
      "history"
    ],
    "expected_stderr": "",
    "expected_exit": 0
  }
]
